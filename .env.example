# =====================================
# APP CONFIG
# =====================================
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# =====================================
# DATABASE (PostgreSQL)
# =====================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/oquv_markaz?schema=public
# Eslatma: agar kompyuteringizda native Postgres yo'q bo'lsa, 5433 o'rniga 5432 ishlatishingiz mumkin
# (lekin docker-compose.yml'da ham mos ravishda o'zgartiring)

# =====================================
# REDIS (Cache / Sessions)
# =====================================
REDIS_URL=redis://localhost:6379

# =====================================
# JWT
# =====================================
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_REFRESH_SECRET=change-me-too-different-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =====================================
# BCRYPT
# =====================================
BCRYPT_ROUNDS=12

# =====================================
# SEED (demo ma'lumotlar)
# =====================================
# Server ishga tushganda demo ma'lumotlar avtomatik yuklanadi (baza bo'sh bo'lsa).
# O'chirish uchun: AUTO_SEED=false
AUTO_SEED=true
# Super_admin parolini shu yerdan belgilash mumkin (default: SuperAdmin123)
SEED_ADMIN_PASSWORD=SuperAdmin123

# =====================================
# SMTP (Email)
# =====================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="O'quv Markaz <noreply@oquv.uz>"

# =====================================
# PAYMENT INTEGRATIONS
# =====================================
PAYME_MERCHANT_ID=your-merchant-id
PAYME_KEY=your-payme-key
CLICK_SERVICE_ID=your-service-id
CLICK_SECRET=your-click-secret

# =====================================
# FILE UPLOAD
# =====================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# =====================================
# CORS / FRONTEND
# =====================================
FRONTEND_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:8000,http://localhost:5173,http://127.0.0.1:5500

# =====================================
# THROTTLING (rate limit)
# =====================================
THROTTLE_TTL=250
THROTTLE_LIMIT=1000
LOGIN_THROTTLE_TTL=900
LOGIN_THROTTLE_LIMIT=65
