// =====================================
// Prisma Schema — O'quv Markaz Backend
// =====================================

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================================
// ENUMS
// =====================================

enum UserRole {
  super_admin
  admin
  teacher
  student
}

enum UserStatus {
  active
  inactive
  banned
}

enum Gender {
  male
  female
}

enum StudentStatus {
  active
  inactive
  graduated
}

enum TeacherStatus {
  active
  on_leave
  inactive
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

enum CourseStatus {
  draft
  active
  archived
}

enum GroupStatus {
  upcoming
  active
  completed
  cancelled
}

enum GroupFormat {
  offline
  online
  hybrid
}

enum GroupStudentStatus {
  active
  left
  completed
}

enum LessonStatus {
  scheduled
  completed
  cancelled
}

enum AttendanceStatus {
  present
  late
  absent
}

enum AssignmentStatus {
  pending
  submitted
  graded
}

enum ExamStatus {
  upcoming
  active
  completed
  cancelled
}

enum StudentExamStatus {
  pending
  completed
  missed
}

enum PaymentMethod {
  payme
  click
  cash
  card
  bank
}

enum PaymentStatus {
  pending
  paid
  partial
  refunded
  failed
}

// =====================================
// USERS
// =====================================

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique
  phone           String     @unique
  passwordHash    String     @map("password_hash")
  role            UserRole   @default(student)
  status          UserStatus @default(active)
  firstName       String     @map("first_name")
  lastName        String     @map("last_name")
  middleName      String?    @map("middle_name")
  birthDate       DateTime?  @map("birth_date") @db.Date
  gender          Gender?
  address         String?
  avatarUrl       String?    @map("avatar_url")
  emailVerifiedAt DateTime?  @map("email_verified_at")
  phoneVerifiedAt DateTime?  @map("phone_verified_at")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")
  deletedAt       DateTime?  @map("deleted_at")

  // Relations
  student               Student?
  teacher               Teacher?
  sessions              Session[]
  passwordResets        PasswordResetToken[]
  emailVerifications    EmailVerificationToken[]
  markedAttendances     Attendance[]            @relation("attendances_marked_by")
  createdAssignments    Assignment[]            @relation("assignments_created_by")
  createdExpenses       Expense[]               @relation("expenses_created_by")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model Student {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @unique @map("user_id") @db.Uuid
  studentId       String        @unique @map("student_id") // ST-0123
  parentFirstName String        @map("parent_first_name")
  parentLastName  String        @map("parent_last_name")
  parentPhone     String        @map("parent_phone")
  motherName      String?       @map("mother_name")
  motherPhone     String?       @map("mother_phone")
  enrolledAt      DateTime      @map("enrolled_at") @db.Date
  status          StudentStatus @default(active)

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups             GroupStudent[]
  attendances        Attendance[]
  studentAssignments StudentAssignment[]
  studentExams       StudentExam[]
  payments           Payment[]

  @@index([studentId])
  @@map("students")
}

model Teacher {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @unique @map("user_id") @db.Uuid
  teacherId   String        @unique @map("teacher_id") // TC-001
  specialty   String
  experience  Int           @default(0)
  bio         String?
  hireDate    DateTime      @map("hire_date") @db.Date
  salary      Decimal       @default(0) @db.Decimal(15, 2)
  rating      Decimal       @default(0) @db.Decimal(3, 2)
  socialLinks Json?         @map("social_links") // {github, linkedin, telegram}
  status      TeacherStatus @default(active)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups Group[]

  @@index([teacherId])
  @@map("teachers")
}

// =====================================
// SESSIONS (refresh tokens)
// =====================================

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  ipAddress    String?  @map("ip_address")
  userAgent    String?  @map("user_agent")
  device       String?
  refreshToken String   @unique @map("refresh_token") @db.Text
  expiresAt    DateTime @map("expires_at")
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
  @@index([expiresAt])
  @@map("sessions")
}

// =====================================
// AUTH TOKENS (forgot password, email verify)
// =====================================

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("password_reset_tokens")
}

// =====================================
// COURSES
// =====================================

model Course {
  id              String       @id @default(uuid()) @db.Uuid
  name            String
  slug            String       @unique
  description     String       @db.Text
  longDescription String       @map("long_description") @db.Text
  category        String
  level           CourseLevel  @default(beginner)
  price           Decimal      @default(0) @db.Decimal(15, 2)
  oldPrice        Decimal?     @map("old_price") @db.Decimal(15, 2)
  durationMonths  Int          @default(1) @map("duration_months")
  lessonsCount    Int          @default(0) @map("lessons_count")
  imageUrl        String?      @map("image_url")
  isFeatured      Boolean      @default(false) @map("is_featured")
  rating          Decimal      @default(0) @db.Decimal(3, 2)
  ratingCount     Int          @default(0) @map("rating_count")
  status          CourseStatus @default(draft)
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  modules CourseModule[]
  groups  Group[]

  @@index([slug])
  @@index([category])
  @@index([status])
  @@index([isFeatured])
  @@map("courses")
}

model CourseModule {
  id       String @id @default(uuid()) @db.Uuid
  courseId String @map("course_id") @db.Uuid
  title    String
  order    Int    @default(0)

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]

  @@index([courseId])
  @@map("course_modules")
}

model CourseLesson {
  id              String @id @default(uuid()) @db.Uuid
  moduleId        String @map("module_id") @db.Uuid
  title           String
  durationMinutes Int    @default(0) @map("duration_minutes")
  order           Int    @default(0)

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([moduleId])
  @@map("course_lessons")
}

// =====================================
// GROUPS
// =====================================

model Group {
  id              String      @id @default(uuid()) @db.Uuid
  name            String      @unique // "Frontend-01"
  courseId        String      @map("course_id") @db.Uuid
  teacherId       String      @map("teacher_id") @db.Uuid
  startDate       DateTime    @map("start_date") @db.Date
  endDate         DateTime?   @map("end_date") @db.Date
  status          GroupStatus @default(upcoming)
  maxStudents     Int         @default(20) @map("max_students")
  currentStudents Int         @default(0) @map("current_students")
  room            String?
  format          GroupFormat @default(offline)
  scheduleDays    Json        @map("schedule_days") // ["mon", "wed", "fri"]
  scheduleTime    String      @map("schedule_time") // "09:00"
  monthlyPrice    Decimal     @default(0) @map("monthly_price") @db.Decimal(15, 2)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  course      Course         @relation(fields: [courseId], references: [id])
  teacher     Teacher        @relation(fields: [teacherId], references: [id])
  students    GroupStudent[]
  lessons     Lesson[]
  assignments Assignment[]
  exams       Exam[]
  payments    Payment[]

  @@index([courseId])
  @@index([teacherId])
  @@index([status])
  @@map("groups")
}

model GroupStudent {
  groupId    String             @map("group_id") @db.Uuid
  studentId  String             @map("student_id") @db.Uuid
  enrolledAt DateTime           @default(now()) @map("enrolled_at")
  leftAt     DateTime?          @map("left_at")
  status     GroupStudentStatus @default(active)

  group   Group   @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([groupId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("group_students")
}

// =====================================
// LESSONS (jadval — calendar uchun)
// =====================================

model Lesson {
  id        String       @id @default(uuid()) @db.Uuid
  groupId   String       @map("group_id") @db.Uuid
  date      DateTime     @db.Date
  startTime String       @map("start_time") // "09:00"
  endTime   String       @map("end_time") // "11:00"
  room      String?
  topic     String
  status    LessonStatus @default(scheduled)
  notes     String?      @db.Text
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@index([groupId])
  @@index([date])
  @@index([status])
  @@map("lessons")
}

// =====================================
// ATTENDANCE
// =====================================

model Attendance {
  id        String           @id @default(uuid()) @db.Uuid
  lessonId  String           @map("lesson_id") @db.Uuid
  studentId String           @map("student_id") @db.Uuid
  status    AttendanceStatus
  note      String?
  markedAt  DateTime         @default(now()) @map("marked_at")
  markedBy  String           @map("marked_by") @db.Uuid // user.id (admin yoki teacher)

  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marker  User    @relation("attendances_marked_by", fields: [markedBy], references: [id])

  @@unique([lessonId, studentId])
  @@index([lessonId])
  @@index([studentId])
  @@map("attendances")
}

// =====================================
// ASSIGNMENTS (vazifalar)
// =====================================

model Assignment {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @map("group_id") @db.Uuid
  title       String
  description String   @db.Text
  dueDate     DateTime @map("due_date")
  maxScore    Int      @default(100) @map("max_score")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdBy   String   @map("created_by") @db.Uuid // user.id

  group       Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator     User                @relation("assignments_created_by", fields: [createdBy], references: [id])
  submissions StudentAssignment[]

  @@index([groupId])
  @@index([dueDate])
  @@map("assignments")
}

model StudentAssignment {
  id           String           @id @default(uuid()) @db.Uuid
  assignmentId String           @map("assignment_id") @db.Uuid
  studentId    String           @map("student_id") @db.Uuid
  submittedAt  DateTime?        @map("submitted_at")
  grade        Int?
  comment      String?          @db.Text
  status       AssignmentStatus @default(pending)
  updatedAt    DateTime         @updatedAt @map("updated_at")

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("student_assignments")
}

// =====================================
// EXAMS (imtihonlar)
// =====================================

model Exam {
  id              String     @id @default(uuid()) @db.Uuid
  groupId         String     @map("group_id") @db.Uuid
  title           String
  date            DateTime
  durationMinutes Int        @default(60) @map("duration_minutes")
  questionsCount  Int        @default(0) @map("questions_count")
  maxScore        Int        @default(100) @map("max_score")
  status          ExamStatus @default(upcoming)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  group   Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  results StudentExam[]

  @@index([groupId])
  @@index([date])
  @@index([status])
  @@map("exams")
}

model StudentExam {
  id          String            @id @default(uuid()) @db.Uuid
  examId      String            @map("exam_id") @db.Uuid
  studentId   String            @map("student_id") @db.Uuid
  grade       Int?
  comment     String?           @db.Text
  completedAt DateTime?         @map("completed_at")
  status      StudentExamStatus @default(pending)
  updatedAt   DateTime          @updatedAt @map("updated_at")

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId])
  @@index([studentId])
  @@index([status])
  @@map("student_exams")
}

// =====================================
// PAYMENTS (talabalar to'lovi)
// =====================================

model Payment {
  id            String        @id @default(uuid()) @db.Uuid
  studentId     String        @map("student_id") @db.Uuid
  groupId       String        @map("group_id") @db.Uuid
  amount        Decimal       @db.Decimal(15, 2)
  method        PaymentMethod
  status        PaymentStatus @default(pending)
  paidAt        DateTime?     @map("paid_at")
  dueDate       DateTime      @map("due_date") @db.Date
  transactionId String?       @map("transaction_id") // to'lov tizimi ID
  receiptUrl    String?       @map("receipt_url")
  notes         String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  group   Group   @relation(fields: [groupId], references: [id])

  @@index([studentId])
  @@index([groupId])
  @@index([status])
  @@index([dueDate])
  @@index([paidAt])
  @@map("payments")
}

// =====================================
// EXPENSES (markazning xarajatlari)
// =====================================

model ExpenseCategory {
  id       String    @id @default(uuid()) @db.Uuid
  name     String    @unique // "Ish haqi", "Ijara", "Marketing"
  color    String    @default("#2563EB") // hex
  expenses Expense[]

  @@map("expense_categories")
}

model Expense {
  id            String   @id @default(uuid()) @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  description   String
  amount        Decimal  @db.Decimal(15, 2)
  date          DateTime @db.Date
  createdBy     String   @map("created_by") @db.Uuid // user.id
  attachmentUrl String?  @map("attachment_url")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  creator  User            @relation("expenses_created_by", fields: [createdBy], references: [id])

  @@index([categoryId])
  @@index([date])
  @@map("expenses")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("email_verification_tokens")
}
